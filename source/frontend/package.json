{
  "name": "workload-discovery-ui",
  "version": "2.3.16",
  "private": true,
  "description": "UI code for the Workload Discovery solution",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@aws-sdk/util-utf8-browser": "^3.259.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "amplify-graphql-docs-generator": "^2.2.4",
    "eslint": "^8.44.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "history": "^4.10.1",
    "jsdom": "^25.0.1",
    "msw": "^2.12.3",
    "node-fetch": "^3.3.1",
    "playwright": "^1.56.1",
    "prettier": "^3.0.0",
    "vite": "^6.2.1",
    "vite-plugin-eslint2": "^5.0.3",
    "vite-plugin-svgr": "4.3.0",
    "vitest": "^4.0.0",
    "vitest-browser-react": "^2.0.0"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "6.15.0",
    "@cloudscape-design/collection-hooks": "1.0.69",
    "@cloudscape-design/components": "3.0.944",
    "@cloudscape-design/design-tokens": "3.0.55",
    "@cloudscape-design/global-styles": "1.0.40",
    "@tanstack/react-query": "5.67.0",
    "@uiw/react-json-view": "1.12.2",
    "aws-amplify": "6.16.2",
    "crypto-js": "4.2.0",
    "currency-symbol-map": "5.0.1",
    "cytoscape": "3.33.0",
    "cytoscape-cola": "^2.5.1",
    "cytoscape-expand-collapse": "4.1.0",
    "cytoscape-fcose": "2.1.0",
    "cytoscape-grid-guide": "2.3.3",
    "dayjs": "1.8.28",
    "file-saver": "2.0.2",
    "filefy": "0.1.10",
    "js-file-download": "0.4.12",
    "lodash.forown": "4.4.0",
    "lodash.isobject": "3.0.2",
    "object-hash": "3.0.0",
    "p-limit": "4.0.0",
    "ramda": "0.28.0",
    "randomcolor": "0.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^3.1.4",
    "react-papaparse": "3.11.1",
    "react-router-dom": "5.3.4",
    "react-use": "^17.4.0",
    "sass": "1.38.0",
    "svgcanvas": "2.5.0",
    "ua-parser-js": "1.0.35",
    "valid-filename": "4.0.0"
  },
  "overrides": {
    "minimatch": "10.2.4"
  },
  "scripts": {
    "start": "vite",
    "build": "npm run clean && npm i && NODE_OPTIONS=--max_old_space_size=4096 vite build && npm run build:zip && npm run build:dist",
    "serve": "vite preview",
    "pretest": "npm i && rm -rf coverage && mkdir coverage",
    "test": "vitest run --coverage --passWithNoTests --silent passed-only",
    "test:jsdom": "vitest run --project jsdom",
    "test:browser": "vitest run --project browser",
    "test:ci": "npm ci && npx playwright install --with-deps && npm run test",
    "test:watch": "vitest --coverage --passWithNoTests",
    "build:zip": "cd dist && zip -rq --exclude=settings.js ../ui.zip . && cd ..",
    "lint": "eslint",
    "clean": "rm -rf build",
    "build:dist": "mv ui.zip dist/",
    "graphql-gen": "npm i -save-dev amplify-graphql-docs-generator && amplify-graphql-docs-generator --schema ../backend/graphql/schema/perspective-api.graphql --output src/API/GraphQL/ --language javascript --separateFiles true"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "msw": {
    "workerDirectory": "public"
  }
}
